# Production / staging secrets template — copy to a host-local file (gitignore).
# Prefer AWS Secrets Manager / SSM / Vault over plain files when possible.
# See docs/DEPLOYMENT.md

# Node
NOVAPANDA_ENV=production
NOVAPANDA_STRICT_ENV=1
NOVAPANDA_AUTH=1
NOVAPANDA_DB=/var/lib/novapanda/node.sqlite
NOVAPANDA_REPUTATION_DB=/var/lib/novapanda/reputation.sqlite
NOVAPANDA_OPERATOR_DB=/var/lib/novapanda/operator.sqlite
NOVAPANDA_ADMIN_TOKEN=<rotate-me>
NOVAPANDA_STEWARD_TOKEN=<rotate-me>
NOVAPANDA_SETTLEMENT=mock
NOVAPANDA_SETTLEMENT_ENV=sandbox
NOVAPANDA_MARKETPLACE=0
# NOVAPANDA_FORCE_REAL_RUNNER=1

# Persistence note:
# NOVAPANDA_OPERATOR_DB — operator console / tickets / local ops state (body layer).
# NOVAPANDA_DB — exchange store. Keep backups; never commit.

# Stripe (licensed rail) — live only on PCI-aware hosts
NOVAPANDA_FIAT_COMPLIANCE=stripe
NOVAPANDA_FIAT_PROVIDER=stripe
NOVAPANDA_FIAT_URL=https://api.stripe.com/v1
STRIPE_LIVE_SECRET=sk_live_REPLACE
NOVAPANDA_FIAT_API_KEY=sk_live_REPLACE

# Chain body
NOVAPANDA_EVM_RPC_URL=https://REPLACE.example/v1/YOUR_KEY
NOVAPANDA_SOLANA_RPC_URL=https://REPLACE.example
SIGNER_BROADCAST_KEY=REPLACE_NEVER_COMMIT

# Partner rails
NOVAPANDA_X402_URL=
NOVAPANDA_X402_API_KEY=
NOVAPANDA_AP2_URL=
NOVAPANDA_AP2_API_KEY=
