# 阶段 1：mock 结算 — 全球参考节点（无真钱）
# 复制为 production.env，勿提交含密钥的文件

TROODON_AUTH=1
TROODON_SETTLEMENT=mock
TROODON_DB=/data/troodon.sqlite

# 必填：保护 POST /admin/sweep
TROODON_ADMIN_TOKEN=change-me-to-long-random-secret

# 生产建议关闭 v2 直至运维成熟
TROODON_WITNESS_V2=0
TROODON_FEDERATION_V2=0

# 可选：信誉 gate（公开免费 tier 可先关闭）
# TROODON_REP_MIN_SCORE=

TROODON_TIMEOUT_CONTRACT=300
TROODON_TIMEOUT_ESCROW=300
TROODON_TIMEOUT_DELIVER=600
TROODON_TIMEOUT_VERIFY=600
TROODON_TIMEOUT_CONFIRM=300

# 进程
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=2
