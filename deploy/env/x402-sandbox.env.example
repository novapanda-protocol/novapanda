# 阶段 2：x402 sandbox — 在 mock 稳定运行后切换
# 使用独立 DB 与环境，勿与 mock 生产混库

TROODON_AUTH=1
TROODON_SETTLEMENT=x402
TROODON_X402_URL=https://your-x402-sandbox-partner.example
TROODON_X402_API_KEY=your-sandbox-api-key

TROODON_DB=/data/troodon-x402.sqlite
TROODON_ADMIN_TOKEN=change-me-to-long-random-secret

TROODON_WITNESS_V2=0
TROODON_FEDERATION_V2=0

# AP2/Fiat 保持关闭直至单独评估
# TROODON_SETTLEMENT=ap2
# TROODON_AP2_URL=
# TROODON_FIAT_URL=

UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=2
