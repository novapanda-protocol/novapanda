# NovaPanda — environment template (copy to `.env` locally; never commit secrets)
# Docs: docs/DEPLOYMENT.md · novapanda/config.py

# ─── Node core ───────────────────────────────────────────────
NOVAPANDA_AUTH=1
NOVAPANDA_DB=./data/novapanda.sqlite
NOVAPANDA_REPUTATION_DB=./data/novapanda.reputation.sqlite
NOVAPANDA_OPERATOR_DB=./data/novapanda.operator.sqlite
NOVAPANDA_ADMIN_TOKEN=
NOVAPANDA_STEWARD_TOKEN=
NOVAPANDA_ARBITRATOR=

# ─── Settlement rails (ADR-0002: adapter, not CORE) ──────────
NOVAPANDA_SETTLEMENT=mock
# NOVAPANDA_RAILS=mock,x402,sandbox
# NOVAPANDA_DEFAULT_RAIL=mock
NOVAPANDA_SETTLEMENT_ENV=sandbox

# ─── Runtime mode / hardening ────────────────────────────────
# development | production — production enables stricter checks
NOVAPANDA_ENV=development
# NOVAPANDA_STRICT_ENV=1          # fail startup on EnvironmentValidator errors
# NOVAPANDA_FORCE_REAL_RUNNER=1   # prefer RealExchangeRunner over in-memory

# ─── Marketplace / NP-REP (default off) ──────────────────────
NOVAPANDA_MARKETPLACE=0
NOVAPANDA_REP_MIN_SCORE=
NOVAPANDA_REP_GATE_STRICT=0
NOVAPANDA_REP_WEIGHTS=

# ─── Verifier ────────────────────────────────────────────────
NOVAPANDA_VERIFIER=schema
# NOVAPANDA_LLM_JUDGE=http
# NOVAPANDA_LLM_GATEWAY_URL=
# NOVAPANDA_LLM_API_KEY=
# NOVAPANDA_LLM_MODEL=

# ─── Feature flags ───────────────────────────────────────────
NOVAPANDA_WITNESS_V2=0
NOVAPANDA_FEDERATION_V2=0
NOVAPANDA_CLAIM_MODE=mock
# NOVAPANDA_CLAIM_DB=

# ─── Fiat / Stripe compliance gateway ────────────────────────
# Mode: stub | licensed | stripe
NOVAPANDA_FIAT_COMPLIANCE=stub
NOVAPANDA_FIAT_URL=
NOVAPANDA_FIAT_API_KEY=
NOVAPANDA_FIAT_PROVIDER=stripe
# Production live secret — inject via secret manager, not git
STRIPE_LIVE_SECRET=
# Sandbox / test
STRIPE_TEST_SECRET=
NOVAPANDA_STRIPE_TEST_PM=pm_card_visa

# ─── Chain RPC + signer (wallet body layer) ──────────────────
NOVAPANDA_EVM_RPC_URL=
NOVAPANDA_SOLANA_RPC_URL=
# Hex / base58 private key material for signer_broadcast ONLY on the ops host
SIGNER_BROADCAST_KEY=
# Optional CAIP-2 defaults
NOVAPANDA_EVM_CHAIN_ID=eip155:1
NOVAPANDA_SOLANA_CLUSTER=solana:mainnet

# ─── x402 / AP2 partner gateways ─────────────────────────────
NOVAPANDA_X402_URL=
NOVAPANDA_X402_API_KEY=
NOVAPANDA_AP2_URL=
NOVAPANDA_AP2_API_KEY=

# ─── Timeouts (seconds) ──────────────────────────────────────
NOVAPANDA_TIMEOUT_CONTRACT=300
NOVAPANDA_TIMEOUT_ESCROW=300
NOVAPANDA_TIMEOUT_DELIVER=600
# NOVAPANDA_TIMEOUT_VERIFY=
# NOVAPANDA_TIMEOUT_CONFIRM=

# ─── Ontology / rules (optional paths) ───────────────────────
# NOVAPANDA_ONTOLOGY=
# NOVAPANDA_RULES=
